{
  "name": "@college-erp/backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "nest start --watch",
    "worker": "ts-node -r tsconfig-paths/register src/worker.ts",
    "build": "nest build",
    "start": "node dist/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "latest",
    "@nestjs/common": "latest",
    "@nestjs/config": "latest",
    "@nestjs/core": "latest",
    "@nestjs/jwt": "latest",
    "@nestjs/passport": "latest",
    "@nestjs/platform-express": "latest",
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "bcryptjs": "latest",
    "bullmq": "latest",
    "class-transformer": "latest",
    "class-validator": "latest",
    "ioredis": "latest",
    "passport": "latest",
    "passport-jwt": "latest",
    "pg": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest"
  },
  "devDependencies": {
    "@nestjs/cli": "latest",
    "@nestjs/schematics": "latest",
    "@nestjs/testing": "latest",
    "@types/bcryptjs": "latest",
    "@types/node": "latest",
    "@types/passport-jwt": "latest",
    "@types/pg": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "prisma": "latest",
    "source-map-support": "latest",
    "ts-node": "latest",
    "tsconfig-paths": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
